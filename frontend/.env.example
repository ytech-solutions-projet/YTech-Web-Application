# Configuration de l'environnement - YTECH Application Web

# URL de l'API backend
REACT_APP_API_URL=http://localhost:5000
REACT_APP_CSRF_COOKIE_NAME=ytech_csrf

# Configuration de l'application
REACT_APP_NAME=YTECH
REACT_APP_VERSION=3.0.0
REACT_APP_DESCRIPTION=Votre expert en développement web professionnel au Maroc

# Configuration de sécurité
REACT_APP_ENCRYPTION_ENABLED=true
REACT_APP_SESSION_TIMEOUT=3600000
REACT_APP_RATE_LIMIT_ENABLED=true

# Configuration du stockage
REACT_APP_STORAGE_PREFIX=ytech_
REACT_APP_CACHE_DURATION=300000

# Configuration du logging
REACT_APP_LOG_LEVEL=info
REACT_APP_LOG_TO_SERVER=true

# Configuration des fonctionnalités
REACT_APP_ANALYTICS_ENABLED=false
REACT_APP_PWA_ENABLED=true
REACT_APP_OFFLINE_SUPPORT=true

# Configuration des services tiers
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_

# Configuration de développement
REACT_APP_DEV_MODE=false
REACT_APP_DEBUG_MODE=false
REACT_APP_MOCK_API=false

# Configuration du cache
REACT_APP_CACHE_STRATEGY=networkFirst
REACT_APP_CACHE_VERSION=1.0.0

# Configuration de l'authentification
REACT_APP_AUTH_TIMEOUT=1800000
REACT_APP_TOKEN_REFRESH_ENABLED=true

# Configuration des notifications
REACT_APP_NOTIFICATIONS_ENABLED=true
REACT_APP_NOTIFICATIONS_DURATION=5000

# Configuration du thème
REACT_APP_DEFAULT_THEME=light
REACT_APP_THEME_PERSISTENCE=true

# Configuration de la langue
REACT_APP_DEFAULT_LANGUAGE=fr
REACT_APP_SUPPORTED_LANGUAGES=fr,en,ar

# Configuration des uploads
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Configuration du monitoring
REACT_APP_PERFORMANCE_MONITORING=true
REACT_APP_ERROR_TRACKING=true

# Configuration du SEO
REACT_APP_SITE_URL=https://ytech.ma
REACT_APP_SITE_NAME=YTECH
REACT_APP_SITE_DESCRIPTION=Développement web professionnel au Maroc
