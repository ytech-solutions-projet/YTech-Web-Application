# Environment Variables Template
# Copy this file to .env and update with your values

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=ytech_user
DB_PASSWORD=your-postgres-password
DB_NAME=ytech_db
DB_SSL=false

# Server Configuration
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
SESSION_SECRET=your-super-secret-session-key-change-this-in-production-minimum-32-characters
BCRYPT_ROUNDS=12

# Admin Seed
ADMIN_SEED_NAME=YTECH Admin
ADMIN_SEED_EMAIL=admin@ytech.ma
ADMIN_SEED_PASSWORD=set-a-strong-admin-password-here
ADMIN_SEED_PHONE=+212600000000
ADMIN_SEED_COMPANY=YTECH

# Auth / Cookies
AUTH_COOKIE_NAME=ytech_auth
AUTH_COOKIE_SAME_SITE=strict
AUTH_COOKIE_SECURE=false
TRUST_PROXY=false
ALLOWED_ORIGINS=http://localhost:3000

# API Limits
JSON_BODY_LIMIT=100kb
URLENCODED_BODY_LIMIT=50kb
REGISTER_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_MAX=10
PASSWORD_RESET_RATE_LIMIT_MAX=5

# Email Configuration
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your-mailtrap-user
EMAIL_PASS=your-mailtrap-pass
ADMIN_EMAIL=contact@ytech.ma

# Payment Configuration (optional)
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
